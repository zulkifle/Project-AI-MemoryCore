# [AI_NAME] auto-load hook - SessionStart
# Generated from Feature/Auto-Load-Hook-System/hooks/session-start.ps1.template
# Fires on Claude Code: startup | resume | clear | compact

# Hook protocol requirement: drain stdin before producing output.
# Without this, subsequent input to Claude Code can hang.
[Console]::In.ReadToEnd() | Out-Null

# Inject context (NOT simulated user input) telling Claude to load the AI's memory.
# Write-Output is used instead of Write-Host for safe piped-context behavior.
Write-Output "AUTOLOAD: You are [AI_NAME]. Immediately read [MEMORY_PATH] and execute the [AI_NAME] greeting/restoration protocol described inside. Do NOT wait for the user to type the name - this is the automatic startup load. Greet the user once memory is restored."
