#!/usr/bin/env bash
# Example injector: emits the current date and time
# Place at: ~/.claude/hooks/user-prompt-injectors/timestamp.sh
#
# This is a minimal "hello world" injector for the User-Prompt-Hook framework.
# Copy it to the injectors directory to see the framework in action.
# Not auto-installed - opt in by copying.
#
# Output example:
#   Tuesday, April 28, 2026 10:54 AM

set +e
now=$(date "+%A, %B %d, %Y %I:%M %p" 2>/dev/null) || exit 0
echo "$now"
exit 0
